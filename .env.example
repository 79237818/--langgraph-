# ══════════════════════════════════════════════════════════════════
# 默认中转服务（所有 LLM 共用，除非在 config.py 里单独覆盖）
# ══════════════════════════════════════════════════════════════════
# 填写你的 OpenAI 兼容中转地址，例如：
#   one-api:    https://your-one-api.com/v1
#   new-api:    https://your-new-api.com/v1
#   openrouter: https://openrouter.ai/api/v1
OPENAI_BASE_URL=https://gcli.ggchan.dev/v1
OPENAI_API_KEY=gg-gcli-4gqp2uSy8NZDfjxPsSVnOOdp2wSnqrGB56iBlQKj1Q8

# ══════════════════════════════════════════════════════════════════
# 单独覆盖某个角色/组件的中转（可选）
# 在 config.py 的 CHARACTER_MODELS / COMPONENT_MODELS 对应条目里
# 直接填写 base_url 和 api_key 字段即可，无需在这里设置。
# ══════════════════════════════════════════════════════════════════

# ══════════════════════════════════════════════════════════════════
# LangSmith 追踪（可选）
# ══════════════════════════════════════════════════════════════════
LANGSMITH_PROJECT=rpg-game
# LANGSMITH_API_KEY=lsv2...
